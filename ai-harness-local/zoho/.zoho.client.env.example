# Copia este archivo como ai-harness-local/zoho/.zoho.client.env.
# No versionar .zoho.client.env.
#
# Este archivo contiene las credenciales OAuth reutilizables.
# Al portar el arnes, podes conservar solo este archivo local. El chequeo de
# inicio crea ai-harness-local/zoho/.zoho.config si falta y te indica que IDs de
# Zoho quedan por configurar para el repo actual.

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
